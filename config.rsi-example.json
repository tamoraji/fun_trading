{
  "symbols": [
    "AAPL",
    "MSFT",
    "SPY"
  ],
  "poll_interval_seconds": 300,
  "market_data": {
    "provider": "yahoo",
    "bar_interval": "5m",
    "lookback": "5d",
    "timeout_seconds": 10
  },
  "strategy": {
    "name": "rsi",
    "params": {
      "period": 14,
      "oversold": 30,
      "overbought": 70
    }
  },
  "market_session": {
    "enabled": true,
    "timezone": "America/New_York",
    "weekdays": [0, 1, 2, 3, 4],
    "start": "09:30",
    "end": "16:00"
  },
  "signal_history": {
    "enabled": true,
    "path": "signal_history.jsonl"
  },
  "notifiers": [
    {
      "type": "console"
    }
  ]
}
